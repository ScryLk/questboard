generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch", "fullTextIndex"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║  ENUMS                                                          ║
// ╚══════════════════════════════════════════════════════════════════╝

enum Plan {
  FREE
  ADVENTURER
  LEGENDARY
  PLAYER_PLUS
}

enum SubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELLED
  EXPIRED
  PAUSED
}

enum BillingCycle {
  MONTHLY
  YEARLY
}

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
  REFUNDED
  CHARGED_BACK
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
  DECLINED
}

enum AchievementCategory {
  SESSIONS
  COMBAT
  SOCIAL
  CREATION
  EXPLORATION
  DEDICATION
  SPECIAL
}

enum AchievementRarity {
  COMMON
  UNCOMMON
  RARE
  EPIC
  LEGENDARY
}

enum NotificationType {
  SESSION_INVITE
  SESSION_STARTING
  SESSION_LIVE
  SESSION_ENDED
  SESSION_KICK
  FRIEND_REQUEST
  FRIEND_ACCEPTED
  FRIEND_ONLINE
  ACHIEVEMENT_UNLOCKED
  PAYMENT_SUCCESS
  PAYMENT_FAILED
  TRIAL_ENDING
  PLAN_CHANGED
  SYSTEM_ANNOUNCEMENT
  SYSTEM_UPDATE
}

enum SessionType {
  PRIVATE
  PUBLIC
  ASYNC
}

enum SessionStatus {
  IDLE
  LIVE
  PAUSED
  ENDED
  ARCHIVED
}

enum SessionVisibility {
  UNLISTED
  LISTED
  FRIENDS_ONLY
}

enum PlayerRole {
  GM
  CO_GM
  PLAYER
  SPECTATOR
}

enum RsvpStatus {
  PENDING
  CONFIRMED
  DECLINED
  TENTATIVE
}

enum InviteStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
  REVOKED
}

enum ScheduleStatus {
  SCHEDULED
  STARTED
  COMPLETED
  CANCELLED
  SKIPPED
}

enum ReportReason {
  HARASSMENT
  HATE_SPEECH
  INAPPROPRIATE
  SPAM
  CHEATING
  IMPERSONATION
  OTHER
}

enum ReportStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  DISMISSED
}

enum GridType {
  SQUARE
  HEX_FLAT
  HEX_POINTY
  NONE
}

enum MapGenerationStatus {
  QUEUED
  PROCESSING
  COMPLETED
  ACCEPTED
  REJECTED
  FAILED
}

enum TokenType {
  PC
  NPC
  ENEMY
  ALLY
  OBJECT
  VEHICLE
  EFFECT
}

enum FogShapeType {
  RECTANGLE
  CIRCLE
  POLYGON
  FREEHAND
  CELL
}

enum WallType {
  NORMAL
  WINDOW
  ETHEREAL
  INVISIBLE
  TERRAIN
}

enum DoorState {
  CLOSED
  OPEN
  LOCKED
  SECRET
}

enum LightType {
  POINT
  CONE
  AMBIENT
}

enum LayerContentType {
  IMAGE
  DRAWING
}

enum AnnotationType {
  FREEHAND
  ARROW
  CIRCLE
  RECTANGLE
  TEXT
  RULER
  CONE
  SPHERE
  LINE
  CUBE
}

enum AnnotationVisibility {
  ALL
  GM_ONLY
  SPECIFIC
}

enum MapGenMode {
  TEXT_TO_MAP
  VARIATION
  INPAINT
  ENHANCE
  WALLS_DETECT
}

enum ChatChannel {
  GENERAL
  IN_CHARACTER
  WHISPER
  GM_ONLY
  GROUP
}

enum MessageType {
  TEXT
  DICE_ROLL
  SYSTEM
  MEDIA
  NARRATIVE
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║  CORE: USUÁRIO E AUTENTICAÇÃO                                   ║
// ╚══════════════════════════════════════════════════════════════════╝

model User {
  id            String    @id @default(cuid())
  clerkId       String    @unique
  email         String    @unique
  displayName   String
  username      String?   @unique
  avatarUrl     String?
  bannerUrl     String?
  bio           String?   @db.VarChar(500)
  locale        String    @default("pt-BR")
  timezone      String    @default("America/Sao_Paulo")

  // ── Plano ──
  plan          Plan      @default(FREE)
  planExpiresAt DateTime?
  trialUsed     Boolean   @default(false)

  // ── Status ──
  isOnline      Boolean   @default(false)
  lastSeenAt    DateTime  @default(now())
  onboardingCompleted Boolean @default(false)

  // ── Extensível ──
  preferences   Json      @default("{}")
  metadata      Json      @default("{}")

  // ── Timestamps ──
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  // ── Relacionamentos ──
  subscription        Subscription?
  ownedSessions       Session[]
  sessionPlayers      SessionPlayer[]
  characters          Character[]
  messages            Message[]
  diceRolls           DiceRoll[]

  // Social
  sentFriendRequests     Friendship[]     @relation("FriendshipSender")
  receivedFriendRequests Friendship[]     @relation("FriendshipReceiver")
  blockedUsers           UserBlock[]      @relation("BlockSender")
  blockedByUsers         UserBlock[]      @relation("BlockReceiver")

  // Achievements & Stats
  userAchievements    UserAchievement[]
  userStats           UserStats?

  // Notifications
  notifications       Notification[]
  deviceTokens        DeviceToken[]

  // Invites
  sentInvites         SessionInvite[]  @relation("InvitesSent")
  receivedInvites     SessionInvite[]  @relation("InvitesReceived")

  @@index([clerkId])
  @@index([plan])
  @@index([isOnline])
  @@index([deletedAt])
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║  ASSINATURAS E BILLING (Mercado Pago)                           ║
// ╚══════════════════════════════════════════════════════════════════╝

model Subscription {
  id                  String             @id @default(cuid())
  userId              String             @unique
  user                User               @relation(fields: [userId], references: [id])

  mpPreapprovalId     String?            @unique
  mpPayerId           String?
  mpPlanId            String?

  plan                Plan               @default(FREE)
  status              SubscriptionStatus @default(ACTIVE)
  billingCycle        BillingCycle       @default(MONTHLY)
  priceAmountCents    Int                @default(0)
  currency            String             @default("BRL")

  currentPeriodStart  DateTime?
  currentPeriodEnd    DateTime?
  trialStart          DateTime?
  trialEnd            DateTime?
  cancelledAt         DateTime?
  cancelReason        String?

  previousPlan        Plan?
  planChangedAt       DateTime?

  metadata            Json               @default("{}")
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  payments            Payment[]

  @@index([status])
  @@index([mpPreapprovalId])
}

model Payment {
  id                String        @id @default(cuid())
  subscriptionId    String
  subscription      Subscription  @relation(fields: [subscriptionId], references: [id])

  mpPaymentId       String?       @unique
  amountCents       Int
  currency          String        @default("BRL")
  status            PaymentStatus @default(PENDING)
  paidAt            DateTime?
  failedAt          DateTime?
  failureReason     String?
  receiptUrl        String?

  metadata          Json          @default("{}")
  createdAt         DateTime      @default(now())

  @@index([subscriptionId])
  @@index([status])
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║  LIMITES DE PLANO (Configuração — não hardcoded)                ║
// ╚══════════════════════════════════════════════════════════════════╝

model PlanLimit {
  id              String   @id @default(cuid())
  plan            Plan     @unique

  // ── Sessões ──
  maxActiveSessions     Int     @default(2)
  maxPlayersPerSession  Int     @default(5)
  allowPublicSessions   Boolean @default(false)
  allowAsyncSessions    Boolean @default(false)

  // ── Mapas ──
  maxMapUploadMb        Int     @default(5)
  maxAiMapsPerMonth     Int     @default(0)
  allowFogOfWar         Boolean @default(false)
  maxMapLayers          Int     @default(0)
  allowDynamicLighting  Boolean @default(false)
  allowLineOfSight      Boolean @default(false)
  allowInpainting       Boolean @default(false)

  // ── Personagens e Fichas ──
  maxCharactersPerPlayer Int    @default(3)
  allowContextualRolls   Boolean @default(false)
  allowPdfExport         Boolean @default(false)
  availableSheetTemplates Json  @default("[\"generic\"]")

  // ── Comunicação ──
  allowWhisper           Boolean @default(false)
  allowSecretNotes       Boolean @default(false)
  maxFileUploadMb        Int     @default(2)
  allowPlayerFileSharing Boolean @default(false)
  allowProgressiveReveal Boolean @default(false)

  // ── Mídia ──
  maxStorageMb          Int     @default(50)
  allowSoundtrack       Boolean @default(false)
  soundtrackTier        String  @default("none")
  allowCustomAudioUpload Boolean @default(false)

  // ── IA ──
  allowNpcAssistant     Boolean @default(false)
  allowAiTimeline       Boolean @default(false)

  // ── Social ──
  maxFriends            Int     @default(50)
  allowInitiativeTracker Boolean @default(false)

  // ── Spectators ──
  allowSpectators       Boolean @default(false)
  maxSpectatorsPerSession Int   @default(0)

  // ── Player Plus específico ──
  maxPersonalStorageMb  Int     @default(0)
  allowPersonalVault    Boolean @default(false)
  allowProfileBadge     Boolean @default(false)
  badgeName             String?

  // ── Extensível ──
  extras                Json    @default("{}")

  updatedAt             DateTime @updatedAt
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║  SISTEMA DE AMIZADE                                             ║
// ╚══════════════════════════════════════════════════════════════════╝

model Friendship {
  id          String           @id @default(cuid())
  senderId    String
  receiverId  String
  status      FriendshipStatus @default(PENDING)

  sender      User @relation("FriendshipSender", fields: [senderId], references: [id])
  receiver    User @relation("FriendshipReceiver", fields: [receiverId], references: [id])

  metadata    Json @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([senderId, receiverId])
  @@index([receiverId, status])
  @@index([senderId, status])
}

model UserBlock {
  id          String   @id @default(cuid())
  blockerId   String
  blockedId   String

  blocker     User     @relation("BlockSender", fields: [blockerId], references: [id])
  blocked     User     @relation("BlockReceiver", fields: [blockedId], references: [id])

  reason      String?
  createdAt   DateTime @default(now())

  @@unique([blockerId, blockedId])
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║  CONQUISTAS (ACHIEVEMENTS)                                      ║
// ╚══════════════════════════════════════════════════════════════════╝

model Achievement {
  id            String              @id @default(cuid())
  key           String              @unique
  name          String
  description   String
  iconUrl       String?
  category      AchievementCategory
  rarity        AchievementRarity   @default(COMMON)

  triggerType   String
  triggerConfig Json

  reward        Json                @default("{}")
  sortOrder     Int                 @default(0)
  isHidden      Boolean             @default(false)
  isActive      Boolean             @default(true)

  metadata      Json                @default("{}")
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  userAchievements UserAchievement[]
}

model UserAchievement {
  id              String      @id @default(cuid())
  userId          String
  achievementId   String

  user            User        @relation(fields: [userId], references: [id])
  achievement     Achievement @relation(fields: [achievementId], references: [id])

  unlockedAt      DateTime    @default(now())
  progress        Json        @default("{}")
  notified        Boolean     @default(false)

  @@unique([userId, achievementId])
  @@index([userId])
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║  ESTATÍSTICAS DO JOGADOR                                        ║
// ╚══════════════════════════════════════════════════════════════════╝

model UserStats {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id])

  totalSessions         Int @default(0)
  totalSessionsAsGm     Int @default(0)
  totalSessionsAsPlayer Int @default(0)
  totalSessionMinutes   Int @default(0)
  longestSessionMinutes Int @default(0)

  totalDiceRolled       Int @default(0)
  totalNat20s           Int @default(0)
  totalNat1s            Int @default(0)
  totalCriticalHits     Int @default(0)

  totalCharactersCreated Int @default(0)
  totalCharacterDeaths   Int @default(0)

  totalMessagesInChat   Int @default(0)
  totalFriendsAdded     Int @default(0)

  totalMapsGenerated    Int @default(0)
  totalCombatsParticipated Int @default(0)

  currentWeeklyStreak   Int @default(0)
  longestWeeklyStreak   Int @default(0)
  lastSessionAt         DateTime?

  extras                Json @default("{}")
  updatedAt             DateTime @updatedAt
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║  NOTIFICAÇÕES                                                   ║
// ╚══════════════════════════════════════════════════════════════════╝

model Notification {
  id          String             @id @default(cuid())
  userId      String
  user        User               @relation(fields: [userId], references: [id])

  type        NotificationType
  title       String
  body        String

  sourceType  String?
  sourceId    String?

  actionUrl   String?
  imageUrl    String?

  isRead      Boolean            @default(false)
  readAt      DateTime?

  channels    Json               @default("[\"in_app\"]")
  groupKey    String?

  data        Json               @default("{}")
  expiresAt   DateTime?
  createdAt   DateTime           @default(now())

  @@index([userId, isRead, createdAt(sort: Desc)])
  @@index([userId, type])
  @@index([groupKey])
}

model DeviceToken {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])

  token       String   @unique
  platform    String
  deviceName  String?

  isActive    Boolean  @default(true)
  lastUsedAt  DateTime @default(now())
  createdAt   DateTime @default(now())

  @@index([userId, isActive])
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║  SESSÃO DE JOGO                                                 ║
// ╚══════════════════════════════════════════════════════════════════╝

model Session {
  id            String        @id @default(cuid())

  // ── Identidade ──
  name          String        @db.VarChar(100)
  slug          String?       @unique
  description   String?       @db.VarChar(2000)
  bannerUrl     String?
  system        String        @default("generic")
  tags          String[]

  // ── Tipo e Acesso ──
  type          SessionType   @default(PRIVATE)
  status        SessionStatus @default(IDLE)
  visibility    SessionVisibility @default(UNLISTED)
  inviteCode    String        @unique @default(cuid())
  password      String?

  // ── Limites ──
  maxPlayers    Int           @default(5)
  allowSpectators Boolean     @default(false)
  maxSpectators Int           @default(0)

  // ── Scheduling ──
  scheduledAt   DateTime?
  timezone      String?
  recurringRule Json?
  remindBeforeMinutes Int?    @default(30)

  // ── Metadata da sessão ──
  sessionNumber Int           @default(1)
  lastPlayedAt  DateTime?
  totalPlaytime Int           @default(0)

  // ── Configurações de jogo ──
  settings      Json          @default("{}")

  // ── Extensível ──
  metadata      Json          @default("{}")

  // ── Owner ──
  ownerId       String
  owner         User          @relation(fields: [ownerId], references: [id])

  // ── Timestamps ──
  startedAt     DateTime?
  endedAt       DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  deletedAt     DateTime?

  // ── Relacionamentos ──
  players       SessionPlayer[]
  invites       SessionInvite[]
  schedules     SessionSchedule[]
  maps          Map[]
  messages      Message[]
  diceRolls     DiceRoll[]
  timeline      TimelineEvent[]
  audioState    SessionAudio[]
  combatState   CombatState?
  sessionLog    SessionLog[]
  reports       SessionReport[]

  @@index([ownerId])
  @@index([status])
  @@index([type, visibility, status])
  @@index([inviteCode])
  @@index([scheduledAt])
  @@index([system, type, visibility])
  @@index([deletedAt])
  @@index([slug])
}

model SessionPlayer {
  id            String      @id @default(cuid())
  userId        String
  sessionId     String
  characterId   String?
  role          PlayerRole  @default(PLAYER)

  // ── Estado ──
  isConnected   Boolean     @default(false)
  lastConnectedAt DateTime?
  isMuted       Boolean     @default(false)
  isBanned      Boolean     @default(false)

  // ── Stats desta sessão ──
  totalMinutesPlayed Int    @default(0)
  totalDiceRolled    Int    @default(0)
  totalMessages      Int    @default(0)
  sessionsAttended   Int    @default(0)

  // ── Preferências por sessão ──
  nickname      String?
  color         String?

  // ── RSVP ──
  rsvpStatus    RsvpStatus? @default(PENDING)

  // ── Extensível ──
  metadata      Json        @default("{}")

  // ── Timestamps ──
  joinedAt      DateTime    @default(now())
  leftAt        DateTime?
  kickedAt      DateTime?
  kickReason    String?

  user          User        @relation(fields: [userId], references: [id])
  session       Session     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  character     Character?  @relation(fields: [characterId], references: [id])

  @@unique([userId, sessionId])
  @@index([sessionId, isConnected])
  @@index([sessionId, role])
  @@index([userId])
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║  CONVITES PARA SESSÃO                                           ║
// ╚══════════════════════════════════════════════════════════════════╝

model SessionInvite {
  id            String        @id @default(cuid())
  sessionId     String
  session       Session       @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  // ── Quem convidou ──
  invitedById   String
  invitedBy     User          @relation("InvitesSent", fields: [invitedById], references: [id])

  // ── Quem foi convidado ──
  invitedUserId String?
  invitedUser   User?         @relation("InvitesReceived", fields: [invitedUserId], references: [id])
  invitedEmail  String?

  // ── Estado ──
  status        InviteStatus  @default(PENDING)
  role          PlayerRole    @default(PLAYER)
  message       String?       @db.VarChar(500)

  // ── Validade ──
  expiresAt     DateTime?
  maxUses       Int?
  usedCount     Int           @default(0)

  // ── Token de convite ──
  token         String        @unique @default(cuid())

  metadata      Json          @default("{}")
  createdAt     DateTime      @default(now())
  respondedAt   DateTime?

  @@index([sessionId, status])
  @@index([invitedUserId, status])
  @@index([invitedEmail])
  @@index([token])
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║  AGENDAMENTO DE SESSÕES                                         ║
// ╚══════════════════════════════════════════════════════════════════╝

model SessionSchedule {
  id            String   @id @default(cuid())
  sessionId     String
  session       Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  // ── Ocorrência ──
  scheduledFor  DateTime
  duration      Int?

  // ── Estado ──
  status        ScheduleStatus @default(SCHEDULED)
  cancelReason  String?

  // ── Recorrência ──
  isRecurring   Boolean  @default(false)
  parentRuleId  String?

  // ── RSVP Summary ──
  confirmedCount Int     @default(0)
  declinedCount  Int     @default(0)
  pendingCount   Int     @default(0)

  // ── Notificações ──
  reminderSent  Boolean  @default(false)
  startingSent  Boolean  @default(false)

  metadata      Json     @default("{}")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([sessionId, scheduledFor])
  @@index([sessionId, scheduledFor])
  @@index([scheduledFor, status])
  @@index([status])
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║  ESTADO DE COMBATE                                              ║
// ╚══════════════════════════════════════════════════════════════════╝

model CombatState {
  id            String   @id @default(cuid())
  sessionId     String   @unique
  session       Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  // ── Estado ──
  isActive      Boolean  @default(false)
  round         Int      @default(1)
  turnIndex     Int      @default(0)

  // ── Initiative Order ──
  initiativeOrder Json   @default("[]")

  // ── Histórico ──
  combatLog     Json     @default("[]")

  metadata      Json     @default("{}")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║  LOG DA SESSÃO                                                  ║
// ╚══════════════════════════════════════════════════════════════════╝

model SessionLog {
  id          String   @id @default(cuid())
  sessionId   String
  session     Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  event       String
  actorId     String?
  targetId    String?
  data        Json     @default("{}")

  createdAt   DateTime @default(now())

  @@index([sessionId, createdAt(sort: Desc)])
  @@index([sessionId, event])
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║  DENÚNCIAS DE SESSÃO                                            ║
// ╚══════════════════════════════════════════════════════════════════╝

model SessionReport {
  id            String       @id @default(cuid())
  sessionId     String
  session       Session      @relation(fields: [sessionId], references: [id])
  reporterId    String

  reason        ReportReason
  description   String?      @db.VarChar(1000)
  evidence      Json         @default("[]")

  status        ReportStatus @default(OPEN)
  resolvedById  String?
  resolvedAt    DateTime?
  resolution    String?

  createdAt     DateTime     @default(now())

  @@index([sessionId])
  @@index([status])
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║  ENTIDADES DE JOGO                                              ║
// ╚══════════════════════════════════════════════════════════════════╝

model Character {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id])

  name          String
  system        String    @default("generic")
  avatarUrl     String?
  isPublic      Boolean   @default(false)

  sheetData     Json      @default("{}")
  metadata      Json      @default("{}")

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  sessionPlayers SessionPlayer[]

  @@index([userId])
}

model CharacterTemplate {
  id      String @id @default(cuid())
  system  String
  name    String
  schema  Json
  version Int    @default(1)

  @@unique([system, name])
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║  MAPAS E TERRENO                                                ║
// ╚══════════════════════════════════════════════════════════════════╝

model Map {
  id            String              @id @default(cuid())
  sessionId     String
  session       Session             @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  // ── Identidade ──
  name          String              @db.VarChar(200)
  description   String?             @db.VarChar(1000)
  thumbnailUrl  String?
  sortOrder     Int                 @default(0)

  // ── Imagem base ──
  imageUrl      String
  imageWidth    Int
  imageHeight   Int
  fileSizeMb    Float               @default(0)

  // ── Grid ──
  gridType      GridType            @default(SQUARE)
  gridSize      Int                 @default(32)
  gridOffsetX   Int                 @default(0)
  gridOffsetY   Int                 @default(0)
  gridColor     String              @default("#FFFFFF20")
  gridVisible   Boolean             @default(true)

  // ── Dimensões lógicas (em cells) ──
  cellsWide     Int
  cellsHigh     Int

  // ── Estado ──
  isActive      Boolean             @default(false)
  isLocked      Boolean             @default(false)

  // ── IA ──
  aiGenerated   Boolean             @default(false)
  aiGenerationId String?

  // ── Configurações do mapa ──
  settings      Json                @default("{}")
  metadata      Json                @default("{}")

  // ── Timestamps ──
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  deletedAt     DateTime?

  // ── Relacionamentos ──
  tokens        Token[]
  fogAreas      FogArea[]
  walls         Wall[]
  lightSources  LightSource[]
  layers        MapLayer[]
  annotations   MapAnnotation[]
  generation    MapGeneration?      @relation("GeneratedMap")

  @@index([sessionId, isActive])
  @@index([sessionId, sortOrder])
  @@index([deletedAt])
}

model Token {
  id            String    @id @default(cuid())
  mapId         String
  map           Map       @relation(fields: [mapId], references: [id], onDelete: Cascade)

  // ── Identidade ──
  name          String    @db.VarChar(100)
  type          TokenType
  imageUrl      String?
  color         String?   @default("#6C5CE7")

  // ── Posição (em cells) ──
  x             Float     @default(0)
  y             Float     @default(0)
  rotation      Float     @default(0)

  // ── Tamanho (em cells) ──
  width         Int       @default(1)
  height        Int       @default(1)

  // ── Vinculação ──
  ownerId       String?
  characterId   String?

  // ── Visibilidade ──
  isVisible     Boolean   @default(true)
  isLocked      Boolean   @default(false)
  layer         Int       @default(0)

  // ── Estado de jogo ──
  hp            Json?
  conditions    String[]  @default([])

  // ── Visual ──
  statusRing    String?
  auraRadius    Float?
  auraColor     String?
  elevation     Float     @default(0)
  label         String?

  // ── Extensível ──
  metadata      Json      @default("{}")

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([mapId])
  @@index([mapId, isVisible])
  @@index([ownerId])
}

model FogArea {
  id          String       @id @default(cuid())
  mapId       String
  map         Map          @relation(fields: [mapId], references: [id], onDelete: Cascade)

  isRevealed  Boolean      @default(false)
  shapeType   FogShapeType
  geometry    Json

  metadata    Json         @default("{}")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([mapId])
  @@index([mapId, isRevealed])
}

model Wall {
  id              String    @id @default(cuid())
  mapId           String
  map             Map       @relation(fields: [mapId], references: [id], onDelete: Cascade)

  // ── Segmento ──
  x1              Float
  y1              Float
  x2              Float
  y2              Float

  // ── Tipo ──
  wallType        WallType  @default(NORMAL)

  // ── Propriedades ──
  blocksMovement  Boolean   @default(true)
  blocksVision    Boolean   @default(true)
  blocksLight     Boolean   @default(true)

  // ── Porta ──
  isDoor          Boolean   @default(false)
  doorState       DoorState @default(CLOSED)
  doorLocked      Boolean   @default(false)

  metadata        Json      @default("{}")
  createdAt       DateTime  @default(now())

  @@index([mapId])
}

model LightSource {
  id              String    @id @default(cuid())
  mapId           String
  map             Map       @relation(fields: [mapId], references: [id], onDelete: Cascade)

  // ── Posição ──
  x               Float
  y               Float

  // ── Alcance ──
  brightRadius    Float
  dimRadius       Float

  // ── Visual ──
  color           String    @default("#FFF4E0")
  intensity       Float     @default(1.0)

  // ── Tipo ──
  lightType       LightType @default(POINT)

  // ── Cone ──
  coneAngle       Float?
  coneDirection   Float?

  // ── Comportamento ──
  isEnabled       Boolean   @default(true)
  flickers        Boolean   @default(false)
  flickerIntensity Float    @default(0.1)

  // ── Vinculação a token ──
  tokenId         String?
  isStatic        Boolean   @default(true)

  metadata        Json      @default("{}")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([mapId])
  @@index([tokenId])
}

model MapLayer {
  id          String           @id @default(cuid())
  mapId       String
  map         Map              @relation(fields: [mapId], references: [id], onDelete: Cascade)

  name        String           @db.VarChar(100)
  sortOrder   Int              @default(0)
  isVisible   Boolean          @default(true)
  isLocked    Boolean          @default(false)
  opacity     Float            @default(1.0)

  layerType   LayerContentType @default(IMAGE)
  imageUrl    String?
  objects     Json             @default("[]")

  metadata    Json             @default("{}")
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([mapId, sortOrder])
}

model MapAnnotation {
  id          String               @id @default(cuid())
  mapId       String
  map         Map                  @relation(fields: [mapId], references: [id], onDelete: Cascade)
  authorId    String

  type        AnnotationType
  data        Json

  visibleTo   AnnotationVisibility @default(ALL)
  isPersistent Boolean             @default(false)

  createdAt   DateTime             @default(now())

  @@index([mapId])
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║  GERAÇÃO DE MAPAS POR IA                                        ║
// ╚══════════════════════════════════════════════════════════════════╝

model MapGeneration {
  id            String              @id @default(cuid())
  sessionId     String
  requestedById String

  // ── Input ──
  mode          MapGenMode
  prompt        String?             @db.VarChar(2000)
  parameters    Json                @default("{}")

  // ── Inpainting ──
  sourceMapId   String?
  maskData      String?             @db.Text
  inpaintPrompt String?             @db.VarChar(500)

  // ── Variation ──
  variationOfId String?

  // ── Output ──
  status        MapGenerationStatus @default(QUEUED)
  resultUrl     String?
  resultWidth   Int?
  resultHeight  Int?
  mapId         String?             @unique
  map           Map?                @relation("GeneratedMap", fields: [mapId], references: [id])

  // ── AI Provider ──
  provider      String?
  model         String?
  providerJobId String?

  // ── Custos ──
  estimatedCostCents Int?
  actualCostCents    Int?

  // ── Timing ──
  queuedAt      DateTime            @default(now())
  startedAt     DateTime?
  completedAt   DateTime?
  failedAt      DateTime?
  errorMessage  String?

  metadata      Json                @default("{}")
  createdAt     DateTime            @default(now())

  @@index([sessionId])
  @@index([requestedById])
  @@index([status])
}

model AiUsageMonthly {
  id             String @id @default(cuid())
  userId         String
  year           Int
  month          Int

  mapsGenerated  Int    @default(0)
  inpaintsUsed   Int    @default(0)
  totalCostCents Int    @default(0)

  @@unique([userId, year, month])
  @@index([userId])
}

model Message {
  id          String      @id @default(cuid())
  sessionId   String
  userId      String
  channel     ChatChannel @default(GENERAL)
  content     String
  type        MessageType @default(TEXT)
  targetId    String?
  metadata    Json?

  session     Session     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id])

  createdAt   DateTime    @default(now())

  @@index([sessionId, createdAt])
  @@index([sessionId, channel])
}

model DiceRoll {
  id          String   @id @default(cuid())
  sessionId   String
  userId      String
  formula     String
  results     Json
  total       Int
  context     String?
  isSecret    Boolean  @default(false)

  session     Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id])

  createdAt   DateTime @default(now())

  @@index([sessionId, createdAt])
  @@index([userId])
}

model TimelineEvent {
  id          String   @id @default(cuid())
  sessionId   String
  type        String
  data        Json
  session     Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@index([sessionId, createdAt])
}

model AudioTrack {
  id          String   @id @default(cuid())
  category    String
  name        String
  url         String
  duration    Int
  isBuiltin   Boolean  @default(true)
}

model SessionAudio {
  id          String   @id @default(cuid())
  sessionId   String
  layer       String   @default("ambient")
  trackId     String
  volume      Float    @default(0.5)
  isPlaying   Boolean  @default(false)
  session     Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

// ╔══════════════════════════════════════════════════════════════════╗
// ║  AUDIT LOG                                                      ║
// ╚══════════════════════════════════════════════════════════════════╝

model AuditLog {
  id          String   @id @default(cuid())
  userId      String?
  action      String
  targetType  String?
  targetId    String?
  changes     Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([userId, createdAt(sort: Desc)])
  @@index([action, createdAt(sort: Desc)])
  @@index([targetType, targetId])
}
