{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "skipLibCheck": true,
    "paths": {
      "@questboard/shared": [
        "../../packages/shared/src"
      ],
      "@questboard/shared/*": [
        "../../packages/shared/src/*"
      ],
      "@questboard/ui": [
        "../../packages/ui/src"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx"
  ]
}