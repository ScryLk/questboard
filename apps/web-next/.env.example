# ── Clerk (auth) ──
# Pegue em https://dashboard.clerk.com → seu app → API Keys.
# Publishable Key começa com `pk_test_` (dev) ou `pk_live_` (prod).
# Secret Key começa com `sk_test_` ou `sk_live_`.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Webhook do Clerk (configurado em dashboard.clerk.com → Webhooks).
# Endpoint: https://<seu-dominio>/api/v1/webhooks/clerk
# Use Svix-Signing-Secret pra validar.
CLERK_WEBHOOK_SECRET=whsec_...

# Rotas customizadas (espelham as do middleware.ts e do ClerkProvider).
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/login
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ── Backend API ──
# Aponta pra apps/api (Fastify). Em dev local: http://localhost:3001.
# Em produção: URL do app Heroku do backend.
NEXT_PUBLIC_API_URL=http://localhost:3001

# ── IA (Gemini) ──
# Pegue em https://aistudio.google.com/apikey. Mantenha server-side
# apenas — nunca exponha como NEXT_PUBLIC.
GEMINI_API_KEY=
