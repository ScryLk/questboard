{
  "name": "@questboard/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc --project tsconfig.build.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:api": "vitest run"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1004.0",
    "@aws-sdk/s3-request-presigner": "^3.1004.0",
    "@clerk/backend": "^3.0.1",
    "@fastify/cors": "^11.0.1",
    "@fastify/multipart": "^9.4.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/websocket": "^11.0.2",
    "@prisma/client": "^6.19.2",
    "@questboard/db": "workspace:*",
    "@questboard/game-engine": "workspace:*",
    "@questboard/shared": "workspace:*",
    "bullmq": "^5.70.1",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "firebase-admin": "^13.7.0",
    "ioredis": "^5.10.0",
    "prisma": "^6.19.2",
    "socket.io": "^4.8.1",
    "svix": "^1.86.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.5",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "vitest": "^3.0.7"
  }
